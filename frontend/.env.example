# eerc = token privado EncryptedERC + ZK (default). avax = transferencias nativas AVAX.
NEXT_PUBLIC_PAYMENT_ASSET=eerc

# RPC Fuji (opcional; hay default público)
NEXT_PUBLIC_AVALANCHE_FUJI_RPC=https://api.avax-test.network/ext/bc/C/rpc
# Por defecto el browser usa /api/rpc/fuji (mismo origen). Poné 1 para RPC directo.
# NEXT_PUBLIC_FUJI_RPC_DIRECT=1
# FUJI_RPC_UPSTREAM_URL=https://api.avax-test.network/ext/bc/C/rpc

# Contrato eERC20 desplegado en Fuji (EncryptedERC). Si vacío, usa demo Fuji del SDK.
NEXT_PUBLIC_EERC_CONTRACT_ADDRESS=

# standalone | converter
NEXT_PUBLIC_EERC_MODE=standalone

# Solo en modo converter: ERC20 subyacente
NEXT_PUBLIC_CONVERTER_ERC20_ADDRESS=

# Bloque inicial para indexadores (futuro)
NEXT_PUBLIC_INDEXER_FROM_BLOCK=0

# Contrapartes demo — direcciones 0x completas en Fuji (registradas en eERC)
NEXT_PUBLIC_DEMO_BANKAOOL=
NEXT_PUBLIC_DEMO_FINNOVA=
NEXT_PUBLIC_DEMO_RUTALOG=

# Si está definida, Auditoría pide esta clave antes de mostrar el panel (demo pública)
NEXT_PUBLIC_AUDITOR_PREVIEW_SECRET=

# Barra técnica de checks (solo desarrollo). En producción dejar sin definir.
# NEXT_PUBLIC_SHOW_DEV_STATUS_BAR=1

# Neon PostgreSQL (solo servidor — nunca NEXT_PUBLIC)
# Pooled (app) + direct (migraciones drizzle-kit push)
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# Demo en Vercel (solo servidor — ver docs/env.vercel.snippet)
DEMO_TEAM_PASSPHRASE=
# Desbloqueo automático para Bankaool/FinNova (sin código en UI). Poné 0 para desactivar.
# DEMO_AUTO_UNLOCK=0
DEMO_BANKAOOL_DECRYPTION_KEY=
DEMO_FINNOVA_DECRYPTION_KEY=
